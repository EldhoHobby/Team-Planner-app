# Reverse proxy + TLS termination.
#
# Two site blocks:
#  1) Public domain — automatic, trusted Let's Encrypt certificate. Requires the
#     domain's DNS to point at your public IP and ports 80+443 forwarded to this
#     host (port 80 is used for the ACME challenge).
#  2) Local + LAN — internal self-signed cert for https://planner.localhost and
#     https://192.168.10.71.
#
# If the public cert can't be issued yet (DNS/forwarding not ready), Caddy keeps
# retrying in the background and the local/LAN block still works.

eldho-planner01.duckdns.org {
	encode gzip
	reverse_proxy app:3000
}

planner.localhost, 192.168.10.71 {
	encode gzip
	reverse_proxy app:3000
	tls internal
}
