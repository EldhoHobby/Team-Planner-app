# Reverse proxy + TLS termination.
#
# Offline / LAN setup: a single self-signed (internal) certificate serves the app
# over HTTPS for localhost and this host's LAN IP — no internet / Let's Encrypt
# needed. Change/add the IP below to match the host, and use a static IP or DHCP
# reservation so it doesn't change out from under you.
#
# To expose a public domain with a trusted Let's Encrypt cert instead (requires
# internet + ports 80/443 reachable from outside), add a block like:
#   your-domain.example.org {
#     encode gzip
#     reverse_proxy app:3000
#   }

planner.localhost, 10.210.4.65 {
  encode gzip
  reverse_proxy app:3000
  tls internal
}
