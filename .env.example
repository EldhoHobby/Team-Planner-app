# ─── Copy to .env and fill in. Never commit .env. ───
#DreamsLIVE Solutions

# Postgres (used by the db container and the app's DATABASE_URL)
DB_PASSWORD=change-me-strong-password
# Inside Compose the host is the service name "db". For local non-Docker dev use localhost.
DATABASE_URL=postgres://planner:change-me-strong-password@db:5432/planner

# Session signing secret — generate with: openssl rand -base64 32
SESSION_SECRET=change-me-32-byte-random-secret

# Public URL the app is served at (used for building reset/invite links)
APP_URL=https://planner.localhost

# ─── Optional: SMTP for self-service password reset & invite emails ───
# Leave blank to run fully air-gapped. Admin-issued reset/invite links work without this.
SMTP_URL=
SMTP_FROM=no-reply@planner.local

# Attachment limits
MAX_UPLOAD_MB=10

# Path (inside the container) to the QEI timesheet Excel template used when
# generating timesheets. The compose files bind-mount a host folder here so you
# can update the template without rebuilding. Default (baked into the image):
TIMESHEET_TEMPLATE_PATH=/app/timesheet-template/Time_Sheet_Template.xlsm

# Seed a built-in demo technician crew on first visit to /schedule (only when the
# org has none). Leave false/unset in production so it starts with no technicians;
# set to true for dev/demo convenience.
SEED_DEFAULT_TECHNICIANS=false

# ─── Optional: Email → task ingest (monitors a Gmail inbox over IMAP) ───
# Send/Bcc an email to this mailbox with "@username" tags in the subject/body to
# create dashboard tasks for those people (no tag → assigned to the sender, if
# their From address matches a user). Requires outbound internet from the host.
# Gmail setup: enable 2-Step Verification, then create an App Password
# (Google Account → Security → App passwords) and put it in IMAP_PASSWORD.
EMAIL_INGEST_ENABLED=false
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASSWORD=
EMAIL_POLL_SECONDS=120

# ─── Optional: local AI email summarizer (Ollama — no cloud, no cost) ───
# When enabled, ingested emails get an AI-written action title + summary, and a
# target date / priority when the email states them. Runs entirely on-prem in
# the "ollama" container; if the model is down/slow, ingest falls back to the
# raw subject/excerpt. First "docker compose up" with this enabled downloads
# the model (~2 GB) once into the ollama_models volume.
# Model guidance: qwen2.5:3b-instruct needs ~4 GB free RAM while summarizing
# (CPU is fine). Small hosts: llama3.2:1b. NVIDIA GPU: qwen2.5:7b-instruct.
EMAIL_AI_ENABLED=false
EMAIL_AI_MODEL=qwen2.5:3b-instruct
OLLAMA_URL=http://ollama:11434

# ─── Automatic nightly database backups ───
# The backup sidecar dumps the database to ./backups once at startup and then
# every 24 hours, deleting dumps older than this many days.
BACKUP_KEEP_DAYS=14
