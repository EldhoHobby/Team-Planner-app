// Team Planner — data model
// Tenancy rule: every domain row carries orgId; team-scoped rows also carry teamId.
// All access goes through the scoped helpers in src/lib/db — never query unscoped.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Identity & tenancy ───────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  teams       Team[]
  invitations Invitation[]
  projects    Project[]
  tasks       Task[]
  events      CalendarEvent[]
  timeOff     TimeOff[]
  attachments Attachment[]
  technicians Technician[]
  techTimeOff TechnicianTimeOff[]
  holidays    Holiday[]
  auditLogs   AuditLog[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  isActive     Boolean  @default(true)
  theme        String? // "light" | "dark" — per-user UI theme (null = follow system)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships     Membership[]
  teamMemberships TeamMembership[]
  sessions        Session[]
  resetTokens     PasswordResetToken[]
  taskAssignments TaskAssignment[]
  timeOff         TimeOff[]
  uploads         Attachment[]
  invitesSent     Invitation[]         @relation("InvitedBy")
  technician      Technician?
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

// User's membership in an organization.
model Membership {
  id     String  @id @default(cuid())
  role   OrgRole @default(MEMBER)
  userId String
  orgId  String

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
}

model Team {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org         Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members     TeamMembership[]
  projects    Project[]
  events      CalendarEvent[]
  timeOff     TimeOff[]
  invitations Invitation[]

  @@unique([orgId, name])
  @@index([orgId])
}

enum TeamRole {
  MANAGER
  MEMBER
}

model TeamMembership {
  id     String   @id @default(cuid())
  role   TeamRole @default(MEMBER)
  userId String
  teamId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, teamId])
  @@index([teamId])
}

// ─────────────────────────── Auth tokens & sessions ───────────────────────────

// Server-side sessions so we can revoke. The cookie holds a random token;
// only its SHA-256 hash is stored here, so a DB leak can't be used to log in.
model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// Single-use, time-boxed. issuedByUserId set when an admin generates the link.
model PasswordResetToken {
  id             String    @id @default(cuid())
  userId         String
  tokenHash      String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  issuedByUserId String? // null = self-service; set = admin-issued
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

// Invite-only registration. Org-scoped; optional team for direct team placement.
model Invitation {
  id              String       @id @default(cuid())
  orgId           String
  teamId          String?
  email           String
  orgRole         OrgRole      @default(MEMBER)
  teamRole        TeamRole?
  tokenHash       String       @unique
  status          InviteStatus @default(PENDING)
  expiresAt       DateTime
  invitedByUserId String
  createdAt       DateTime     @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team      Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  invitedBy User         @relation("InvitedBy", fields: [invitedByUserId], references: [id])

  @@index([orgId])
  @@index([email])
}

// ─────────────────────────── Projects, boards, tasks ───────────────────────────

model Project {
  id          String   @id @default(cuid())
  orgId       String
  teamId      String
  name        String
  description String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team   Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  boards Board[]
  tasks  Task[]

  @@index([orgId, teamId])
}

model Board {
  id        String   @id @default(cuid())
  projectId String
  name      String   @default("Board")
  createdAt DateTime @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns BoardColumn[]

  @@index([projectId])
}

model BoardColumn {
  id       String @id @default(cuid())
  boardId  String
  name     String
  position Int    @default(0)

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Distinguishes a generic task from a field-service job. FIELD_SERVICE tasks use
// the job* fields + technician/start/end below and appear on the schedule board.
enum TaskKind {
  GENERAL
  FIELD_SERVICE
}

enum JobType {
  COMMISSIONING
  TRAINING
  ANNUAL_MAINTENANCE
  EMERGENCY_SUPPORT
}

// Field-service lifecycle, distinct from the generic TaskStatus.
enum JobStatus {
  UNCONFIRMED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

// A schedulable field engineer. Org-scoped resource with a fixed display colour;
// optionally linked to a real User account (hybrid model — login can come later).
model Technician {
  id        String   @id @default(cuid())
  orgId     String
  name      String
  color     String   @default("#64748b") // free-form hex colour
  active    Boolean  @default(true)
  archived  Boolean  @default(false) // soft-delete: hidden everywhere, history kept
  userId    String?  @unique
  createdAt DateTime @default(now())

  org     Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user    User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  tasks   Task[]
  timeOff TechnicianTimeOff[]

  @@unique([orgId, name])
  @@index([orgId])
}

// Technician unavailability (PTO, training, sick) — blocks scheduling on the board.
model TechnicianTimeOff {
  id           String   @id @default(cuid())
  orgId        String
  technicianId String
  startDate    DateTime
  endDate      DateTime
  reason       String?
  createdAt    DateTime @default(now())

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  technician Technician   @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([technicianId, startDate])
  @@index([orgId])
}

model Task {
  id          String       @id @default(cuid())
  orgId       String
  teamId      String
  projectId   String
  columnId    String?
  kind        TaskKind     @default(GENERAL)
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  estimateHrs Float? // used for derived capacity calculations
  position    Int          @default(0) // ordering within a column
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // ── Field-service (kind = FIELD_SERVICE) ──
  soNumber       String?
  customerName   String?
  jobType        JobType?
  jobStatus      JobStatus? @default(UNCONFIRMED)
  hardwareTarget String?
  startDate      DateTime? // null → sits in the unscheduled backlog
  endDate        DateTime?
  durationDays   Int?
  tentative      Boolean    @default(false) // pencilled-in date → hatched on the board
  technicianId   String?

  org         Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column      BoardColumn?     @relation(fields: [columnId], references: [id], onDelete: SetNull)
  technician  Technician?      @relation(fields: [technicianId], references: [id], onDelete: SetNull)
  assignments TaskAssignment[]
  attachments Attachment[]

  @@index([orgId, teamId, status])
  @@index([projectId, columnId, position])
  @@index([dueDate])
  @@index([orgId, kind, startDate])
  @@index([technicianId, startDate])
}

model TaskAssignment {
  id         String   @id @default(cuid())
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

// ─────────────────────────── Calendar & time-off ───────────────────────────

enum EventType {
  EVENT
  MEETING
  MILESTONE
}

model CalendarEvent {
  id        String    @id @default(cuid())
  orgId     String
  teamId    String
  title     String
  type      EventType @default(EVENT)
  startsAt  DateTime
  endsAt    DateTime
  allDay    Boolean   @default(false)
  createdAt DateTime  @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId, startsAt])
}

enum TimeOffType {
  PTO
  SICK
  OTHER
}

enum TimeOffStatus {
  PENDING
  APPROVED
  REJECTED
}

model TimeOff {
  id        String        @id @default(cuid())
  orgId     String
  teamId    String
  userId    String
  type      TimeOffType   @default(PTO)
  status    TimeOffStatus @default(PENDING)
  startDate DateTime
  endDate   DateTime
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@index([teamId, status])
}

// ─────────────────────────── Attachments ───────────────────────────

// Company/public holidays — surfaced on the calendar; scheduling on one warns.
model Holiday {
  id        String   @id @default(cuid())
  orgId     String
  date      DateTime
  name      String
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, date])
  @@index([orgId])
}

// Change-history trail for jobs, technicians, etc. (what / when / who).
model AuditLog {
  id         String   @id @default(cuid())
  orgId      String
  actorId    String?
  actorEmail String?
  entity     String // "job" | "technician" | "timeoff" | ...
  entityId   String
  action     String // "created" | "updated" | "rescheduled" | "deleted" | ...
  summary    String // human-readable description of the change
  createdAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, entity, entityId])
}

// Metadata in Postgres; bytes on the local uploads volume. Downloads are
// served through the app so RBAC/tenancy is enforced.
model Attachment {
  id           String   @id @default(cuid())
  orgId        String
  taskId       String
  filename     String
  contentType  String
  sizeBytes    Int
  storagePath  String // path within the uploads volume
  uploadedById String
  createdAt    DateTime @default(now())

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  task       Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User         @relation(fields: [uploadedById], references: [id])

  @@index([taskId])
  @@index([orgId])
}
