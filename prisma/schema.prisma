// Team Planner — data model
// Tenancy rule: every domain row carries orgId; team-scoped rows also carry teamId.
// All access goes through the scoped helpers in src/lib/db — never query unscoped.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── Identity & tenancy ───────────────────────────

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  teams       Team[]
  invitations Invitation[]
  projects    Project[]
  tasks       Task[]
  events      CalendarEvent[]
  timeOff     TimeOff[]
  attachments Attachment[]
  techTimeOff TechnicianTimeOff[]
  holidays    Holiday[]
  auditLogs   AuditLog[]
  emailLogs   EmailIngestLog[]
  timesheets  Timesheet[]
  techTasks   TechTask[]
  managerLinks ManagerLink[]
  workGroups   WorkGroup[]
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique // primary login key (lowercase; ^[a-z0-9._-]{3,32}$)
  email        String?  @unique // optional contact address (Postgres allows many NULLs)
  name         String?
  passwordHash String
  isActive     Boolean  @default(true)
  theme        String? // "light" | "dark" — per-user UI theme (null = follow system)
  empNo        String? // employment ID, shown on the timesheet (Emp No #)
  // ── Scheduling attributes (a person IS a technician — one unified record) ──
  color        String   @default("#64748b") // colour on the schedule board
  schedulable  Boolean  @default(true) // appears on the board / can be assigned jobs
  archived     Boolean  @default(false) // soft-delete: hidden everywhere, history kept
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships     Membership[]
  teamMemberships TeamMembership[]
  sessions        Session[]
  resetTokens     PasswordResetToken[]
  taskAssignments TaskAssignment[]
  timeOff         TimeOff[]
  uploads         Attachment[]
  invitesSent     Invitation[]         @relation("InvitedBy")
  jobs            Task[]               @relation("JobAssignee")
  timeOffBlocks   TechnicianTimeOff[]
  timesheets      Timesheet[]
  techTasks       TechTask[]
  managedLinks    ManagerLink[]        @relation("MgrLinkManager")
  managerLinks    ManagerLink[]        @relation("MgrLinkMember")
  workGroups      WorkGroupMembership[]
  actingSessions  Session[]            @relation("SessionActingAs")
}

// Extra reporting lines beyond a person's home department — for the few people
// who also answer to a manager elsewhere. Department managers already see their
// whole department; this covers the exceptions. (member is seen by manager.)
model ManagerLink {
  id        String   @id @default(cuid())
  orgId     String
  managerId String
  memberId  String
  createdAt DateTime @default(now())

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  manager User         @relation("MgrLinkManager", fields: [managerId], references: [id], onDelete: Cascade)
  member  User         @relation("MgrLinkMember", fields: [memberId], references: [id], onDelete: Cascade)

  @@unique([managerId, memberId])
  @@index([orgId, memberId])
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
}

// User's membership in an organization.
model Membership {
  id     String  @id @default(cuid())
  role   OrgRole @default(MEMBER)
  userId String
  orgId  String

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, orgId])
  @@index([orgId])
}

model Team {
  id           String   @id @default(cuid())
  orgId        String
  name         String
  parentTeamId String? // null = top-level department; set = sub-team (e.g. System Eng under Engineering)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  org         Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  parent      Team?            @relation("TeamTree", fields: [parentTeamId], references: [id], onDelete: SetNull)
  children    Team[]           @relation("TeamTree")
  members     TeamMembership[]
  projects    Project[]
  events      CalendarEvent[]
  timeOff     TimeOff[]
  invitations Invitation[]

  @@unique([orgId, name])
  @@index([orgId, parentTeamId])
}

// ── Cross-functional pools (Field Service, Production Release, ...) ──
// Departments (Team) are the reporting/tenancy structure; WorkGroups are the
// scheduling/assignment structure and cut across the department tree.
enum WorkGroupPurpose {
  FIELD_SERVICE
  PRODUCTION_RELEASE
  OTHER
}

enum WorkGroupRole {
  COORDINATOR // oversight (e.g. the System Eng Project Manager on Production Release)
  MEMBER
}

model WorkGroup {
  id        String           @id @default(cuid())
  orgId     String
  name      String
  purpose   WorkGroupPurpose @default(FIELD_SERVICE)
  archived  Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  org     Organization          @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members WorkGroupMembership[]
  tasks   Task[]

  @@unique([orgId, name])
  @@index([orgId])
}

model WorkGroupMembership {
  id          String        @id @default(cuid())
  workGroupId String
  userId      String
  role        WorkGroupRole @default(MEMBER)
  createdAt   DateTime      @default(now())

  workGroup WorkGroup @relation(fields: [workGroupId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workGroupId, userId])
  @@index([userId])
}

enum TeamRole {
  MANAGER
  MEMBER
}

model TeamMembership {
  id     String   @id @default(cuid())
  role   TeamRole @default(MEMBER)
  userId String
  teamId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, teamId])
  @@index([teamId])
}

// ─────────────────────────── Auth tokens & sessions ───────────────────────────

// Server-side sessions so we can revoke. The cookie holds a random token;
// only its SHA-256 hash is stored here, so a DB leak can't be used to log in.
model Session {
  id             String   @id @default(cuid())
  userId         String
  tokenHash      String   @unique
  // "View as" (OWNER-only testing tool): when set, the app renders and acts as
  // this user while audit logs still record the real session owner.
  actingAsUserId String?
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  user     User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  actingAs User? @relation("SessionActingAs", fields: [actingAsUserId], references: [id], onDelete: SetNull)

  @@index([userId])
}

// Single-use, time-boxed. issuedByUserId set when an admin generates the link.
model PasswordResetToken {
  id             String    @id @default(cuid())
  userId         String
  tokenHash      String    @unique
  expiresAt      DateTime
  usedAt         DateTime?
  issuedByUserId String? // null = self-service; set = admin-issued
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum InviteStatus {
  PENDING
  ACCEPTED
  REVOKED
  EXPIRED
}

// Invite-only registration. Org-scoped; optional team for direct team placement.
model Invitation {
  id              String       @id @default(cuid())
  orgId           String
  teamId          String?
  email           String
  orgRole         OrgRole      @default(MEMBER)
  teamRole        TeamRole?
  tokenHash       String       @unique
  status          InviteStatus @default(PENDING)
  expiresAt       DateTime
  invitedByUserId String
  createdAt       DateTime     @default(now())

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team      Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  invitedBy User         @relation("InvitedBy", fields: [invitedByUserId], references: [id])

  @@index([orgId])
  @@index([email])
}

// ─────────────────────────── Projects, boards, tasks ───────────────────────────

model Project {
  id          String   @id @default(cuid())
  orgId       String
  teamId      String
  name        String
  description String?
  archived    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team   Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  boards Board[]
  tasks  Task[]

  @@index([orgId, teamId])
}

model Board {
  id        String   @id @default(cuid())
  projectId String
  name      String   @default("Board")
  createdAt DateTime @default(now())

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  columns BoardColumn[]

  @@index([projectId])
}

model BoardColumn {
  id       String @id @default(cuid())
  boardId  String
  name     String
  position Int    @default(0)

  board Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  tasks Task[]

  @@index([boardId])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

// Distinguishes a generic task from a field-service job. FIELD_SERVICE tasks use
// the job* fields + technician/start/end below and appear on the schedule board.
enum TaskKind {
  GENERAL
  FIELD_SERVICE
}

enum JobType {
  COMMISSIONING
  TRAINING
  ANNUAL_MAINTENANCE
  EMERGENCY_SUPPORT
}

// Where a task came from: created by the person (SELF), assigned to them by
// someone else (MANAGER), or synced in from Outlook (OUTLOOK).
enum TaskOrigin {
  SELF
  MANAGER
  OUTLOOK
}

// Field-service lifecycle, distinct from the generic TaskStatus.
enum JobStatus {
  UNCONFIRMED
  SCHEDULED
  IN_PROGRESS
  COMPLETED
}

// Person unavailability (PTO, training, sick) — blocks scheduling on the board.
// `technicianId` now holds a User id (a person IS a technician). Column name kept
// so the schedule board + Jobs round-trip stay unchanged.
model TechnicianTimeOff {
  id           String   @id @default(cuid())
  orgId        String
  technicianId String // → User.id (the person who's off)
  startDate    DateTime
  endDate      DateTime
  reason       String?
  createdAt    DateTime @default(now())

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  technician User         @relation(fields: [technicianId], references: [id], onDelete: Cascade)

  @@index([technicianId, startDate])
  @@index([orgId])
}

model Task {
  id          String       @id @default(cuid())
  orgId       String
  teamId      String
  projectId   String
  columnId    String?
  kind        TaskKind     @default(GENERAL)
  title       String
  description String?
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  dueDate     DateTime?
  estimateHrs Float? // used for derived capacity calculations
  position    Int          @default(0) // ordering within a column
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // ── Field-service (kind = FIELD_SERVICE) ──
  soNumber       String?
  customerName   String?
  jobType        JobType?
  jobStatus      JobStatus? @default(UNCONFIRMED)
  hardwareTarget String?
  startDate      DateTime? // null → sits in the unscheduled backlog
  endDate        DateTime?
  durationDays   Int?
  tentative      Boolean    @default(false) // pencilled-in date → hatched on the board
  technicianId   String?
  workGroupId    String? // which cross-functional pool the job draws from (null = org-wide)

  // ── Task list (personal / assigned tasks; kind = GENERAL) ──
  origin         TaskOrigin @default(SELF)
  isFieldTrip    Boolean    @default(false)
  location       String?
  assignedById   String? // who assigned it (set for MANAGER origin)
  // Two-way sync scaffolding for a future Outlook / Microsoft Graph connector.
  // Populated when a connector is wired; syncDirty flags a local completion change
  // that still needs to be pushed back to the source system.
  externalId     String? // id in the source system (Outlook)
  externalSource String? // "outlook_todo" | "outlook_event"
  externalUrl    String?
  lastSyncedAt   DateTime?
  syncDirty      Boolean    @default(false)

  org         Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  column      BoardColumn?     @relation(fields: [columnId], references: [id], onDelete: SetNull)
  technician  User?            @relation("JobAssignee", fields: [technicianId], references: [id], onDelete: SetNull)
  workGroup   WorkGroup?       @relation(fields: [workGroupId], references: [id], onDelete: SetNull)
  assignments TaskAssignment[]
  attachments Attachment[]

  @@index([orgId, teamId, status])
  @@index([projectId, columnId, position])
  @@index([dueDate])
  @@index([orgId, kind, startDate])
  @@index([technicianId, startDate])
  @@index([orgId, externalSource, externalId])
}

model TaskAssignment {
  id         String   @id @default(cuid())
  taskId     String
  userId     String
  assignedAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([taskId, userId])
  @@index([userId])
}

// ─────────────────────────── Calendar & time-off ───────────────────────────

enum EventType {
  EVENT
  MEETING
  MILESTONE
}

model CalendarEvent {
  id        String    @id @default(cuid())
  orgId     String
  teamId    String
  title     String
  type      EventType @default(EVENT)
  startsAt  DateTime
  endsAt    DateTime
  allDay    Boolean   @default(false)
  createdAt DateTime  @default(now())

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId, startsAt])
}

enum TimeOffType {
  PTO
  SICK
  OTHER
}

enum TimeOffStatus {
  PENDING
  APPROVED
  REJECTED
}

model TimeOff {
  id        String        @id @default(cuid())
  orgId     String
  teamId    String
  userId    String
  type      TimeOffType   @default(PTO)
  status    TimeOffStatus @default(PENDING)
  startDate DateTime
  endDate   DateTime
  note      String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startDate])
  @@index([teamId, status])
}

// ─────────────────────────── Attachments ───────────────────────────

// Company/public holidays — surfaced on the calendar; scheduling on one warns.
model Holiday {
  id        String   @id @default(cuid())
  orgId     String
  date      DateTime
  name      String
  createdAt DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, date])
  @@index([orgId])
}

// ─────────────────────────── Timesheets ───────────────────────────

// A weekly timesheet for one user (week ends on a Saturday — matches the QEI
// template). Filled in the app, stored here, and rendered into the Excel
// template on generate. One per user per week.
model Timesheet {
  id         String   @id @default(cuid())
  orgId      String
  userId     String
  weekEnding DateTime // the Saturday the week ends on (UTC midnight)
  comments   String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org     Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  entries TimesheetEntry[]

  @@unique([userId, weekEnding])
  @@index([orgId])
}

enum TimesheetSection {
  DIRECT
  INDIRECT
}

// One row of a timesheet. DIRECT rows use so/customer/issue/workDept; INDIRECT
// rows use functionLabel (one of the fixed template categories). Hours are per
// day, Sunday..Saturday.
model TimesheetEntry {
  id            String           @id @default(cuid())
  timesheetId   String
  section       TimesheetSection
  lineNo        Int
  // DIRECT columns
  workDept      String?
  soNumber      String?
  customerName  String?
  issueNo       String?
  // INDIRECT column
  functionLabel String?
  // hours per day
  sun           Float            @default(0)
  mon           Float            @default(0)
  tue           Float            @default(0)
  wed           Float            @default(0)
  thu           Float            @default(0)
  fri           Float            @default(0)
  sat           Float            @default(0)

  timesheet Timesheet @relation(fields: [timesheetId], references: [id], onDelete: Cascade)

  @@index([timesheetId])
}

// ─────────────────────────── Tech task dashboard ───────────────────────────

// Workflow state for a personal/tech task (matches the QEI open-items sheet).
enum TechTaskState {
  NEW
  TODO
  IN_PROGRESS
  HOLD
  DONE
}

// A single open-items entry owned by one person (the technician). A manager can
// create tasks for their direct reports; the person can create their own; a
// future Outlook connector fills OUTLOOK-origin ones. Shown on /dashboard.
model TechTask {
  id           String        @id @default(cuid())
  orgId        String
  ownerId      String // the person this task belongs to
  createdById  String? // who created it
  assignedById String? // who assigned it (set for MANAGER origin)
  title        String
  notes        String?
  priority     Int           @default(3) // 1 = highest, like the sheet
  targetDate   DateTime? // targeted complete date (null = TBD)
  state        TechTaskState @default(NEW)
  completedAt  DateTime? // when it moved to DONE (drives week-by-week grouping)
  origin       TaskOrigin    @default(SELF)
  location     String?
  // Two-way sync scaffolding for a future Outlook / Microsoft Graph connector.
  externalId     String?
  externalSource String? // "outlook_todo" | "outlook_event"
  externalUrl    String?
  lastSyncedAt   DateTime?
  syncDirty      Boolean     @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  owner User         @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@index([orgId, ownerId, state])
  @@index([orgId, externalSource, externalId])
}

// One row per email seen by the ingest poller — feeds the Settings → Email
// statistics. Retention: rows older than 30 days are pruned on each pass.
enum EmailIngestOutcome {
  CREATED // one or more tasks were created
  SKIPPED // no tag + unknown sender, or already imported
  ERROR   // message could not be processed
}

model EmailIngestLog {
  id         String             @id @default(cuid())
  orgId      String
  occurredAt DateTime           @default(now())
  messageId  String? // RFC Message-ID (dedupe reference)
  fromAddr   String?
  subject    String?
  outcome    EmailIngestOutcome
  detail     String? // e.g. "task for Charles Fry", or the skip/error reason
  taskCount  Int                @default(0)

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, occurredAt])
}

// Change-history trail for jobs, technicians, etc. (what / when / who).
model AuditLog {
  id         String   @id @default(cuid())
  orgId      String
  actorId    String?
  actorEmail String?
  entity     String // "job" | "technician" | "timeoff" | ...
  entityId   String
  action     String // "created" | "updated" | "rescheduled" | "deleted" | ...
  summary    String // human-readable description of the change
  createdAt  DateTime @default(now())

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, entity, entityId])
}

// Metadata in Postgres; bytes on the local uploads volume. Downloads are
// served through the app so RBAC/tenancy is enforced.
model Attachment {
  id           String   @id @default(cuid())
  orgId        String
  taskId       String
  filename     String
  contentType  String
  sizeBytes    Int
  storagePath  String // path within the uploads volume
  uploadedById String
  createdAt    DateTime @default(now())

  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  task       Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User         @relation(fields: [uploadedById], references: [id])

  @@index([taskId])
  @@index([orgId])
}
